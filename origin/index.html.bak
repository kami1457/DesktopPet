<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>可自定义桌宠</title>
  <link rel="stylesheet" href="style.css">
</head>
<body>
  <!-- 桌宠容器 -->
  <div id="pet-container">
    <canvas id="pet-canvas"></canvas>
    <div id="pet-speech" class="speech-bubble hidden"></div>
  </div>

  <!-- 设置面板 -->
  <div id="settings-panel" class="panel hidden">
    <div class="panel-header">
      <h2>🐱 桌宠设置</h2>
      <button id="close-settings" class="btn-icon" title="关闭">✕</button>
    </div>

    <div class="panel-body">
      <!-- 图片替换区域 -->
      <section class="section">
        <h3>📷 一键替换形象</h3>
        <p class="hint">上传 <strong>256×256px</strong> 的 PNG 透明底图片即可替换桌宠形象</p>

        <div class="image-slots">
          <div class="image-slot" data-state="idle">
            <div class="slot-preview" id="preview-idle">
              <canvas class="preview-canvas" width="80" height="80"></canvas>
            </div>
            <div class="slot-info">
              <span class="slot-label">🧍 待机形象</span>
              <span class="slot-spec">256×256px PNG</span>
            </div>
            <div class="slot-actions">
              <label class="btn btn-primary btn-sm">
                上传
                <input type="file" accept="image/png,image/gif,image/webp" data-state="idle" class="file-input" hidden>
              </label>
              <button class="btn btn-danger btn-sm btn-reset" data-state="idle" title="恢复默认">↺</button>
            </div>
          </div>

          <div class="image-slot" data-state="happy">
            <div class="slot-preview" id="preview-happy">
              <canvas class="preview-canvas" width="80" height="80"></canvas>
            </div>
            <div class="slot-info">
              <span class="slot-label">😊 开心形象</span>
              <span class="slot-spec">256×256px PNG</span>
            </div>
            <div class="slot-actions">
              <label class="btn btn-primary btn-sm">
                上传
                <input type="file" accept="image/png,image/gif,image/webp" data-state="happy" class="file-input" hidden>
              </label>
              <button class="btn btn-danger btn-sm btn-reset" data-state="happy" title="恢复默认">↺</button>
            </div>
          </div>

          <div class="image-slot" data-state="surprised">
            <div class="slot-preview" id="preview-surprised">
              <canvas class="preview-canvas" width="80" height="80"></canvas>
            </div>
            <div class="slot-info">
              <span class="slot-label">😲 惊讶形象</span>
              <span class="slot-spec">256×256px PNG</span>
            </div>
            <div class="slot-actions">
              <label class="btn btn-primary btn-sm">
                上传
                <input type="file" accept="image/png,image/gif,image/webp" data-state="surprised" class="file-input" hidden>
              </label>
              <button class="btn btn-danger btn-sm btn-reset" data-state="surprised" title="恢复默认">↺</button>
            </div>
          </div>

          <div class="image-slot" data-state="sleep">
            <div class="slot-preview" id="preview-sleep">
              <canvas class="preview-canvas" width="80" height="80"></canvas>
            </div>
            <div class="slot-info">
              <span class="slot-label">😴 睡觉形象</span>
              <span class="slot-spec">256×256px PNG</span>
            </div>
            <div class="slot-actions">
              <label class="btn btn-primary btn-sm">
                上传
                <input type="file" accept="image/png,image/gif,image/webp" data-state="sleep" class="file-input" hidden>
              </label>
              <button class="btn btn-danger btn-sm btn-reset" data-state="sleep" title="恢复默认">↺</button>
            </div>
          </div>
        </div>

        <div class="batch-actions">
          <label class="btn btn-primary">
            📁 批量导入（选择多张图片）
            <input type="file" accept="image/png,image/gif,image/webp" id="batch-import" multiple hidden>
          </label>
          <button class="btn btn-outline" id="export-config">💾 导出配置</button>
          <label class="btn btn-outline">
            📂 导入配置
            <input type="file" accept="application/json" id="import-config" hidden>
          </label>
          <button class="btn btn-danger" id="reset-all">🔄 全部恢复默认</button>
        </div>
      </section>

      <!-- 基本设置 -->
      <section class="section">
        <h3>⚙️ 基本设置</h3>
        <div class="settings-grid">
          <div class="setting-item">
            <label>大小</label>
            <div class="setting-control">
              <input type="range" id="pet-size" min="64" max="512" value="200" step="8">
              <span class="setting-value" id="pet-size-value">200px</span>
            </div>
          </div>
          <div class="setting-item">
            <label>透明度</label>
            <div class="setting-control">
              <input type="range" id="pet-opacity" min="10" max="100" value="100">
              <span class="setting-value" id="pet-opacity-value">100%</span>
            </div>
          </div>
          <div class="setting-item">
            <label>动画速度</label>
            <div class="setting-control">
              <input type="range" id="pet-speed" min="20" max="200" value="100">
              <span class="setting-value" id="pet-speed-value">100%</span>
            </div>
          </div>
          <div class="setting-item">
            <label>镜像翻转</label>
            <div class="setting-control">
              <label class="toggle">
                <input type="checkbox" id="pet-mirror">
                <span class="toggle-slider"></span>
              </label>
            </div>
          </div>
          <div class="setting-item">
            <label>跟随鼠标</label>
            <div class="setting-control">
              <label class="toggle">
                <input type="checkbox" id="pet-follow" checked>
                <span class="toggle-slider"></span>
              </label>
            </div>
          </div>
          <div class="setting-item">
            <label>空闲后入睡（秒）</label>
            <div class="setting-control">
              <input type="range" id="pet-sleep-delay" min="5" max="120" value="30">
              <span class="setting-value" id="pet-sleep-delay-value">30s</span>
            </div>
          </div>
        </div>
      </section>
    </div>
  </div>

  <!-- 右键菜单 -->
  <div id="context-menu" class="context-menu hidden">
    <div class="menu-item" id="menu-settings">⚙️ 设置</div>
    <div class="menu-item" id="menu-reset-pos">📍 回到默认位置</div>
    <hr class="menu-divider">
    <div class="menu-item" id="menu-wave">👋 打招呼</div>
    <div class="menu-item" id="menu-spin">🔄 转圈</div>
    <div class="menu-item" id="menu-sleep">😴 睡觉</div>
    <hr class="menu-divider">
    <div class="menu-item" id="menu-hide">👻 隐藏桌宠</div>
  </div>

  <!-- 显示按钮（隐藏时显示） -->
  <button id="show-pet" class="show-pet-btn hidden" title="显示桌宠">🐱</button>

  <script src="pet.js"></script>
</body>
</html>
